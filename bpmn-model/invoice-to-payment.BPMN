<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_InvoiceToPayment" targetNamespace="http://example.com/invoice-to-payment" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collaboration_InvoiceToPayment" name="Invoice-to-Payment Collaboration">
    <bpmn:participant id="Participant_Vendor" name="Vendor" processRef="Process_Vendor" />
    <bpmn:participant id="Participant_Procurement" name="Procurement Department" processRef="Process_Procurement" />
    <bpmn:participant id="Participant_AP" name="Finance / Accounts Payable" processRef="Process_AP" />
    <bpmn:participant id="Participant_Bank" name="Bank / Payment Provider" processRef="Process_Bank" />
    <bpmn:messageFlow id="Msg_Invoice_Submitted" name="Invoice" sourceRef="V_SendInvoice" targetRef="AP_StartInvoiceReceived" />
    <bpmn:messageFlow id="Msg_Exception_To_Procurement" name="Clarification request" sourceRef="AP_ReviewException" targetRef="P_StartClarification" />
    <bpmn:messageFlow id="Msg_Procurement_To_AP" name="Clarification response" sourceRef="P_SendClarification" targetRef="AP_ReviewException" />
    <bpmn:messageFlow id="Msg_AP_To_Bank" name="Payment instruction" sourceRef="AP_SendPaymentInstruction" targetRef="B_StartPaymentInstruction" />
    <bpmn:messageFlow id="Msg_Bank_To_AP" name="Bank response" sourceRef="B_SendAuthorizationResponse" targetRef="AP_ReceiveBankConfirmation" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Vendor" name="Vendor Process" isExecutable="false">
    <bpmn:startEvent id="V_Start" name="Invoice Prepared">
      <bpmn:outgoing>V_Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sendTask id="V_SendInvoice" name="Send Invoice to Buyer">
      <bpmn:incoming>V_Flow_1</bpmn:incoming>
      <bpmn:outgoing>V_Flow_2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="V_EndInvoiceSent" name="Invoice Sent">
      <bpmn:incoming>V_Flow_2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="V_Flow_1" sourceRef="V_Start" targetRef="V_SendInvoice" />
    <bpmn:sequenceFlow id="V_Flow_2" sourceRef="V_SendInvoice" targetRef="V_EndInvoiceSent" />
  </bpmn:process>
  <bpmn:process id="Process_Procurement" name="Procurement Clarification Process" isExecutable="false">
    <bpmn:startEvent id="P_StartClarification" name="Clarification Requested">
      <bpmn:outgoing>P_Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="P_StartClarification_MessageDefinition" />
    </bpmn:startEvent>
    <bpmn:userTask id="P_ReviewPOGR" name="Review PO / GR Discrepancy">
      <bpmn:incoming>P_Flow_1</bpmn:incoming>
      <bpmn:outgoing>P_Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="P_SendClarification" name="Send Clarification or Correction">
      <bpmn:incoming>P_Flow_2</bpmn:incoming>
      <bpmn:outgoing>P_Flow_3</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="P_EndClarified" name="Clarification Sent">
      <bpmn:incoming>P_Flow_3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="P_Flow_1" sourceRef="P_StartClarification" targetRef="P_ReviewPOGR" />
    <bpmn:sequenceFlow id="P_Flow_2" sourceRef="P_ReviewPOGR" targetRef="P_SendClarification" />
    <bpmn:sequenceFlow id="P_Flow_3" sourceRef="P_SendClarification" targetRef="P_EndClarified" />
  </bpmn:process>
  <bpmn:process id="Process_AP" name="Invoice-to-Payment Process" isExecutable="false">
    <bpmn:laneSet id="LaneSet_AP">
      <bpmn:lane id="Lane_PaymentRecon" name="Payment &#38; Reconciliation Team">
        <bpmn:flowNodeRef>AP_SchedulePayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_ExecutePaymentRun</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_SendPaymentInstruction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_ReceiveBankConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_PaymentSuccessful</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_UpdatePaymentStatus</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_ReconcilePayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_ReconciliationMatched</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_CloseInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_EndPaid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_CreatePaymentFailureCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_EndPaymentFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_CreateReconException</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_EndReconException</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_FinanceApprover" name="Finance Approver">
        <bpmn:flowNodeRef>AP_ReviewException</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_ExceptionResolved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_ApproveInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_InvoiceApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_UpdateRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_NotifyRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_EndRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_APSystem" name="AP Validation System / SAP">
        <bpmn:flowNodeRef>AP_ValidateMandatoryFields</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_DataComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_ValidateVendorMaster</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_VendorExists</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_CheckPOReference</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_POAvailable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_MatchSuccessful</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_ThreeWayMatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_PostInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_ApprovalRequired</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_InvoiceProcessing" name="Invoice Processing Team">
        <bpmn:flowNodeRef>AP_StartInvoiceReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_ReceiveInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_VerifyLegibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_GW_Readable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_RequestMissingInfo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_RequestCorrectedInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_EndPendingCorrection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AP_EndPendingInfo</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="AP_StartInvoiceReceived" name="Invoice Received">
      <bpmn:outgoing>AP_Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="AP_StartInvoiceReceived_MessageDefinition" />
    </bpmn:startEvent>
    <bpmn:receiveTask id="AP_ReceiveInvoice" name="Receive Vendor Invoice">
      <bpmn:incoming>AP_Flow_1</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_2</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:userTask id="AP_VerifyLegibility" name="Verify Invoice Legibility">
      <bpmn:incoming>AP_Flow_2</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="AP_GW_Readable" name="Invoice Readable?">
      <bpmn:incoming>AP_Flow_3</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_4</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="AP_RequestMissingInfo" name="Request Missing Information">
      <bpmn:incoming>AP_Flow_9</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_10</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="AP_ValidateMandatoryFields" name="Validate Mandatory Fields">
      <bpmn:incoming>AP_Flow_4</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="AP_GW_DataComplete" name="Data Complete?">
      <bpmn:incoming>AP_Flow_7</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_8</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="AP_ValidateVendorMaster" name="Validate Vendor Master Data">
      <bpmn:incoming>AP_Flow_8</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="AP_GW_VendorExists" name="Vendor Exists?">
      <bpmn:incoming>AP_Flow_11</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_12</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="AP_CheckPOReference" name="Check PO Reference">
      <bpmn:incoming>AP_Flow_12</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_14</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="AP_GW_POAvailable" name="PO Available?">
      <bpmn:incoming>AP_Flow_14</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_15</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_16</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="AP_GW_MatchSuccessful" name="Match Successful?">
      <bpmn:incoming>AP_Flow_17</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_18</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_19</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="AP_ReviewException" name="Review Vendor / PO Exception">
      <bpmn:incoming>AP_Flow_13</bpmn:incoming>
      <bpmn:incoming>AP_Flow_16</bpmn:incoming>
      <bpmn:incoming>AP_Flow_19</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_20</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="AP_GW_ExceptionResolved" name="Exception Resolved?">
      <bpmn:incoming>AP_Flow_20</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_21</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_22</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="AP_ApproveInvoice" name="Approve Invoice">
      <bpmn:incoming>AP_Flow_25</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_26</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="AP_GW_InvoiceApproved" name="Invoice Approved?">
      <bpmn:incoming>AP_Flow_26</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_27</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_28</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="AP_UpdateRejected" name="Update Invoice Status: Rejected">
      <bpmn:incoming>AP_Flow_22</bpmn:incoming>
      <bpmn:incoming>AP_Flow_28</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_29</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="AP_NotifyRejection" name="Notify Vendor / Procurement">
      <bpmn:incoming>AP_Flow_29</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_30</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="AP_EndRejected" name="Invoice Rejected">
      <bpmn:incoming>AP_Flow_30</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="AP_SchedulePayment" name="Schedule Invoice for Payment">
      <bpmn:incoming>AP_Flow_24</bpmn:incoming>
      <bpmn:incoming>AP_Flow_27</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_31</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="AP_ExecutePaymentRun" name="Execute Payment Run">
      <bpmn:incoming>AP_Flow_31</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_32</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="AP_SendPaymentInstruction" name="Send Payment Instruction">
      <bpmn:incoming>AP_Flow_32</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_33</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="AP_ReceiveBankConfirmation" name="Receive Bank Confirmation">
      <bpmn:incoming>AP_Flow_33</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_34</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:exclusiveGateway id="AP_GW_PaymentSuccessful" name="Payment Successful?">
      <bpmn:incoming>AP_Flow_34</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_35</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_36</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="AP_UpdatePaymentStatus" name="Update Payment Status">
      <bpmn:incoming>AP_Flow_35</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_38</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:manualTask id="AP_ReconcilePayment" name="Reconcile Payment">
      <bpmn:incoming>AP_Flow_38</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_39</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="AP_GW_ReconciliationMatched" name="Reconciliation Matched?">
      <bpmn:incoming>AP_Flow_39</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_40</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_41</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="AP_CloseInvoice" name="Close Invoice">
      <bpmn:incoming>AP_Flow_40</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_42</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="AP_EndPaid" name="Invoice Paid &#38; Reconciled">
      <bpmn:incoming>AP_Flow_42</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:businessRuleTask id="AP_ThreeWayMatch" name="Perform PO / GR / Invoice Match">
      <bpmn:incoming>AP_Flow_15</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_17</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="AP_PostInvoice" name="Post Invoice in SAP">
      <bpmn:incoming>AP_Flow_18</bpmn:incoming>
      <bpmn:incoming>AP_Flow_21</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_23</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="AP_GW_ApprovalRequired" name="Approval Required?">
      <bpmn:incoming>AP_Flow_23</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_24</bpmn:outgoing>
      <bpmn:outgoing>AP_Flow_25</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="AP_CreatePaymentFailureCase" name="Create Payment Failure Case">
      <bpmn:incoming>AP_Flow_36</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_37</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="AP_EndPaymentFailed" name="Payment Failed">
      <bpmn:incoming>AP_Flow_37</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="AP_CreateReconException" name="Create Reconciliation Exception">
      <bpmn:incoming>AP_Flow_41</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_43</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="AP_EndReconException" name="Reconciliation Exception">
      <bpmn:incoming>AP_Flow_43</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="AP_RequestCorrectedInvoice" name="Request Corrected Invoice">
      <bpmn:incoming>AP_Flow_5</bpmn:incoming>
      <bpmn:outgoing>AP_Flow_6</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="AP_EndPendingCorrection" name="Pending Corrected Invoice">
      <bpmn:incoming>AP_Flow_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="AP_EndPendingInfo" name="Pending Missing Information">
      <bpmn:incoming>AP_Flow_10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="AP_Flow_1" sourceRef="AP_StartInvoiceReceived" targetRef="AP_ReceiveInvoice" />
    <bpmn:sequenceFlow id="AP_Flow_2" sourceRef="AP_ReceiveInvoice" targetRef="AP_VerifyLegibility" />
    <bpmn:sequenceFlow id="AP_Flow_3" sourceRef="AP_VerifyLegibility" targetRef="AP_GW_Readable" />
    <bpmn:sequenceFlow id="AP_Flow_4" name="Yes" sourceRef="AP_GW_Readable" targetRef="AP_ValidateMandatoryFields" />
    <bpmn:sequenceFlow id="AP_Flow_5" name="No" sourceRef="AP_GW_Readable" targetRef="AP_RequestCorrectedInvoice" />
    <bpmn:sequenceFlow id="AP_Flow_9" name="No" sourceRef="AP_GW_DataComplete" targetRef="AP_RequestMissingInfo" />
    <bpmn:sequenceFlow id="AP_Flow_10" sourceRef="AP_RequestMissingInfo" targetRef="AP_EndPendingInfo" />
    <bpmn:sequenceFlow id="AP_Flow_7" sourceRef="AP_ValidateMandatoryFields" targetRef="AP_GW_DataComplete" />
    <bpmn:sequenceFlow id="AP_Flow_8" name="Yes" sourceRef="AP_GW_DataComplete" targetRef="AP_ValidateVendorMaster" />
    <bpmn:sequenceFlow id="AP_Flow_11" sourceRef="AP_ValidateVendorMaster" targetRef="AP_GW_VendorExists" />
    <bpmn:sequenceFlow id="AP_Flow_12" name="Yes" sourceRef="AP_GW_VendorExists" targetRef="AP_CheckPOReference" />
    <bpmn:sequenceFlow id="AP_Flow_13" name="No" sourceRef="AP_GW_VendorExists" targetRef="AP_ReviewException" />
    <bpmn:sequenceFlow id="AP_Flow_14" sourceRef="AP_CheckPOReference" targetRef="AP_GW_POAvailable" />
    <bpmn:sequenceFlow id="AP_Flow_15" name="Yes" sourceRef="AP_GW_POAvailable" targetRef="AP_ThreeWayMatch" />
    <bpmn:sequenceFlow id="AP_Flow_16" name="No" sourceRef="AP_GW_POAvailable" targetRef="AP_ReviewException" />
    <bpmn:sequenceFlow id="AP_Flow_17" sourceRef="AP_ThreeWayMatch" targetRef="AP_GW_MatchSuccessful" />
    <bpmn:sequenceFlow id="AP_Flow_18" name="Yes" sourceRef="AP_GW_MatchSuccessful" targetRef="AP_PostInvoice" />
    <bpmn:sequenceFlow id="AP_Flow_19" name="No" sourceRef="AP_GW_MatchSuccessful" targetRef="AP_ReviewException" />
    <bpmn:sequenceFlow id="AP_Flow_20" sourceRef="AP_ReviewException" targetRef="AP_GW_ExceptionResolved" />
    <bpmn:sequenceFlow id="AP_Flow_21" name="Yes" sourceRef="AP_GW_ExceptionResolved" targetRef="AP_PostInvoice" />
    <bpmn:sequenceFlow id="AP_Flow_22" name="No" sourceRef="AP_GW_ExceptionResolved" targetRef="AP_UpdateRejected" />
    <bpmn:sequenceFlow id="AP_Flow_25" name="Yes" sourceRef="AP_GW_ApprovalRequired" targetRef="AP_ApproveInvoice" />
    <bpmn:sequenceFlow id="AP_Flow_26" sourceRef="AP_ApproveInvoice" targetRef="AP_GW_InvoiceApproved" />
    <bpmn:sequenceFlow id="AP_Flow_27" name="Yes" sourceRef="AP_GW_InvoiceApproved" targetRef="AP_SchedulePayment" />
    <bpmn:sequenceFlow id="AP_Flow_28" name="No" sourceRef="AP_GW_InvoiceApproved" targetRef="AP_UpdateRejected" />
    <bpmn:sequenceFlow id="AP_Flow_29" sourceRef="AP_UpdateRejected" targetRef="AP_NotifyRejection" />
    <bpmn:sequenceFlow id="AP_Flow_30" sourceRef="AP_NotifyRejection" targetRef="AP_EndRejected" />
    <bpmn:sequenceFlow id="AP_Flow_24" name="No" sourceRef="AP_GW_ApprovalRequired" targetRef="AP_SchedulePayment" />
    <bpmn:sequenceFlow id="AP_Flow_31" sourceRef="AP_SchedulePayment" targetRef="AP_ExecutePaymentRun" />
    <bpmn:sequenceFlow id="AP_Flow_32" sourceRef="AP_ExecutePaymentRun" targetRef="AP_SendPaymentInstruction" />
    <bpmn:sequenceFlow id="AP_Flow_33" sourceRef="AP_SendPaymentInstruction" targetRef="AP_ReceiveBankConfirmation" />
    <bpmn:sequenceFlow id="AP_Flow_34" sourceRef="AP_ReceiveBankConfirmation" targetRef="AP_GW_PaymentSuccessful" />
    <bpmn:sequenceFlow id="AP_Flow_35" name="Yes" sourceRef="AP_GW_PaymentSuccessful" targetRef="AP_UpdatePaymentStatus" />
    <bpmn:sequenceFlow id="AP_Flow_36" name="No" sourceRef="AP_GW_PaymentSuccessful" targetRef="AP_CreatePaymentFailureCase" />
    <bpmn:sequenceFlow id="AP_Flow_38" sourceRef="AP_UpdatePaymentStatus" targetRef="AP_ReconcilePayment" />
    <bpmn:sequenceFlow id="AP_Flow_39" sourceRef="AP_ReconcilePayment" targetRef="AP_GW_ReconciliationMatched" />
    <bpmn:sequenceFlow id="AP_Flow_40" name="Yes" sourceRef="AP_GW_ReconciliationMatched" targetRef="AP_CloseInvoice" />
    <bpmn:sequenceFlow id="AP_Flow_41" name="No" sourceRef="AP_GW_ReconciliationMatched" targetRef="AP_CreateReconException" />
    <bpmn:sequenceFlow id="AP_Flow_42" sourceRef="AP_CloseInvoice" targetRef="AP_EndPaid" />
    <bpmn:sequenceFlow id="AP_Flow_23" sourceRef="AP_PostInvoice" targetRef="AP_GW_ApprovalRequired" />
    <bpmn:sequenceFlow id="AP_Flow_37" sourceRef="AP_CreatePaymentFailureCase" targetRef="AP_EndPaymentFailed" />
    <bpmn:sequenceFlow id="AP_Flow_43" sourceRef="AP_CreateReconException" targetRef="AP_EndReconException" />
    <bpmn:sequenceFlow id="AP_Flow_6" sourceRef="AP_RequestCorrectedInvoice" targetRef="AP_EndPendingCorrection" />
  </bpmn:process>
  <bpmn:process id="Process_Bank" name="Bank Authorization Process" isExecutable="false">
    <bpmn:startEvent id="B_StartPaymentInstruction" name="Payment Instruction Received">
      <bpmn:outgoing>B_Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="B_StartPaymentInstruction_MessageDefinition" />
    </bpmn:startEvent>
    <bpmn:receiveTask id="B_ReceivePaymentInstruction" name="Receive Payment Instruction">
      <bpmn:incoming>B_Flow_1</bpmn:incoming>
      <bpmn:outgoing>B_Flow_2</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:businessRuleTask id="B_AuthorizePayment" name="Authorize Payment">
      <bpmn:incoming>B_Flow_2</bpmn:incoming>
      <bpmn:outgoing>B_Flow_3</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="B_GW_Authorized" name="Authorized?">
      <bpmn:incoming>B_Flow_3</bpmn:incoming>
      <bpmn:outgoing>B_Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="B_SendAuthorizationResponse" name="Send Approval / Decline Response">
      <bpmn:incoming>B_Flow_4</bpmn:incoming>
      <bpmn:outgoing>B_Flow_5</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="B_EndResponseSent" name="Response Sent">
      <bpmn:incoming>B_Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="B_Flow_1" sourceRef="B_StartPaymentInstruction" targetRef="B_ReceivePaymentInstruction" />
    <bpmn:sequenceFlow id="B_Flow_2" sourceRef="B_ReceivePaymentInstruction" targetRef="B_AuthorizePayment" />
    <bpmn:sequenceFlow id="B_Flow_3" sourceRef="B_AuthorizePayment" targetRef="B_GW_Authorized" />
    <bpmn:sequenceFlow id="B_Flow_4" name="Approved / Declined" sourceRef="B_GW_Authorized" targetRef="B_SendAuthorizationResponse" />
    <bpmn:sequenceFlow id="B_Flow_5" sourceRef="B_SendAuthorizationResponse" targetRef="B_EndResponseSent" />
  </bpmn:process>
